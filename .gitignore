*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments - CRITICAL: Exclude all venv folders
venv/
**/venv/
env/
**/env/
ENV/
env.bak/
venv.bak/
.venv/
**/.venv/

# PyInstaller
*.manifest
*.spec

