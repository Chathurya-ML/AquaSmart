# ============================================
# AWS Configuration
# ============================================

# Enable AWS services (true/false)
USE_AWS=false

# Enable fallback to local storage if AWS fails (true/false)
FALLBACK_ENABLED=true

# AWS Region
AWS_REGION=us-east-1

# ============================================
# AWS Timestream Configuration
# ============================================

TIMESTREAM_DATABASE=irrigation_db
TIMESTREAM_TABLE=sensor_readings

# ============================================
# AWS RDS Configuration
# ============================================

# Leave empty to use local SQLite
RDS_HOST=
RDS_PORT=5432
RDS_DATABASE=irrigation_db
RDS_USER=
RDS_PASSWORD=

# ============================================
# AWS S3 Configuration
# ============================================

S3_BUCKET=irrigation-model-results

# ============================================
# AWS SNS Configuration
# ============================================

# SNS Topic ARN for alerts (leave empty to disable)
SNS_TOPIC_ARN=

# ============================================
# LLM Configuration (for explanations)
# ============================================

# Groq API Key (get free key from https://console.groq.com)
# Uses Llama 3.1 70B by default - fast and free
GROQ_API_KEY=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

# Groq Model (optional, defaults to llama-3.1-70b-versatile)
# Available options:
#   - llama-3.1-70b-versatile (recommended - best quality/speed balance)
#   - mixtral-8x7b-32768 (fast alternative)
#   - llama-3.2-90b-vision-preview (newest, most capable)
GROQ_MODEL=llama-3.1-70b-versatile

# HuggingFace API Key (alternative, get from https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=

# ============================================
# Amazon Bedrock Configuration
# ============================================

# Bedrock model ID (Claude 3 Sonnet recommended)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ============================================
# Application Configuration
# ============================================

APP_ENV=development
LOG_LEVEL=INFO
LSTM_MODEL_PATH=models/soil_forecast_model.pt
RL_MODEL_PATH=models/proactive_irrigation_policy.zip
SENSOR_DATA_PATH=data/sensor_readings.csv
DECISION_DB_PATH=data/irrigation_decisions.db
